    "@heroui/system": "^2.4.15",
    "@heroui/theme": "^2.4.15",
    "@next/third-parties": "^15.2.4",
    "@payloadcms/db-vercel-postgres": "3.79.0",
    "@payloadcms/next": "3.79.0",
    "@payloadcms/payload-cloud": "3.79.0",
    "@payloadcms/plugin-seo": "3.79.0",
    "@payloadcms/richtext-lexical": "3.79.0",
